---
export interface Props {
    title: string;
}

const { title } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Astro description" />
        <meta name="viewport" content="width=device-width" />
        <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon/apple-touch-icon.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon/favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon/favicon-16x16.png" />
        <link rel="manifest" href="/assets/images/favicon/site.webmanifest" />
        <link rel="mask-icon" href="/assets/images/favicon/safari-pinned-tab.svg" color="#5bbad5" />
        <link rel="shortcut icon" href="/assets/images/favicon/favicon.ico" />
        <meta name="msapplication-TileColor" content="#da532c" />
        <meta name="msapplication-config" content="/assets/images/favicon/browserconfig.xml" />
        <meta name="theme-color" content="#121212" />
        <meta name="generator" content={Astro.generator} />
        <!-- RSS Feeds -->
        <link rel="alternate" type="application/rss+xml" title="ummshsh - Blog RSS Feed" href="/rss.xml" />
        <title>{title}</title>
    </head>
    <body>
        <header>
            <div class="header-container">
                <div class="header-content">
                    <a href="/" class="logo">
                        <img src="/assets/images/logo/loves_vector.svg" alt="Logo" />
                    </a>
                    <div class="header-right">
                        <div id="search" class="header-search"></div>
                        <nav class="nav">
                            <a href="/"> posts </a>
                            <a href="/about"> about </a>
                        </nav>
                        <script>
                            const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';
                            document.querySelectorAll('.nav a').forEach(link => {
                                const href = link.getAttribute('href');
                                if (href === currentPath || (href === '/' && currentPath.startsWith('/page'))) {
                                    link.classList.add('active');
                                }
                            });
                        </script>
                    </div>
                </div>
            </div>
        </header>
        <main>
            <div class="container">
                <slot />
            </div>
        </main>
        <script>import '../scripts/search.ts';</script>
    </body>
</html>
