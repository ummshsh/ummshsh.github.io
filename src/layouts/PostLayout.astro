---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
    frontmatter?: {
        title?: string;
        tags?: string;
        date?: string;
        hidden?: boolean;
        file?: string;
    };
    file?: string;
}

const { frontmatter = {}, file = "" } = Astro.props;

// Detect microblog by missing frontmatter elements
const isMicro = !frontmatter.title && !frontmatter.date && !frontmatter.tags;

const filePath = frontmatter.file || file || "";
const slug = filePath.split("/").pop()?.replace(".md", "") || "Unknown";

// Format uniform header for microblogs
const title = isMicro ? `${slug}` : frontmatter.title || slug;

// Format uniform tags for microblogs
let tags = isMicro ? ["microblog"] : frontmatter.tags ? frontmatter.tags.split(" ") : [];

const dateMatch = slug.match(/(\d{4}-\d{1,2}-\d{1,2})/);
const date = isMicro ? (dateMatch ? dateMatch[1] : null) : frontmatter.date || (dateMatch ? dateMatch[1] : null);
---

<BaseLayout title={title}>
    <article class="post">
        <header class="post-header">
            <h1 class="post-title">{title}</h1>
            {
                date && (
                    <time class="post-date" datetime={date}>
                        {new Date(date).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })}
                    </time>
                )
            }
            {
                tags.length > 0 && (
                    <div class="post-tags">
                        {tags.map((tag) => (
                            <a href={`/tags/${tag}`} class="tag">
                                {tag}
                            </a>
                        ))}
                    </div>
                )
            }
        </header>

        <div class="post-content">
            <slot />
        </div>
    </article>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const postContent = document.querySelector(".post-content");
            if (!postContent) return;

            postContent.innerHTML = postContent.innerHTML.replace(/\(\:\:([^)]+)\)/g, '<span class="hover-footnote" data-title="$1">*</span>');

            postContent.innerHTML = postContent.innerHTML.replace(
                /<img\s+([^>]*?src="([^"]+)"[^>]*?)>\s*\{\:\.clickableimg\}/g,
                '<a href="$2" target="_blank" rel="noopener noreferrer"><img $1 class="clickableimg"></a>'
            );

            // URL-encode spaces in image src attributes
            postContent.querySelectorAll("img").forEach(function(img) {
                img.src = img.src.replace(/ /g, "%20");
            });
        });
    </script>
</BaseLayout>
