---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";

export async function getStaticPaths() {
    const postFiles = import.meta.glob("../../posts/*.md", { eager: true });

    return Object.entries(postFiles).map(([path, file]: [string, any]) => {
        const slug = path.split("/").pop()?.replace(".md", "") || "";
        return {
            params: { slug },
            props: { post: file, slug },
        };
    });
}

const { post, slug } = Astro.props;

const frontmatter = post.frontmatter || {};

// THE FIX: Regular posts have a title in their frontmatter, microblogs don't.
const isMicro = !frontmatter.title;

const cleanSlugTitle = slug.replace(/^\d{4}-\d{1,2}-\d{1,2}-/, "").replace(/-/g, " ");
const microTitle = slug.replace(/^(\d{4}-\d{2}-\d{2})-(\d{2})-(\d{2})-\d{2}$/, "$1 $2:$3");
const title = isMicro ? microTitle : frontmatter.title || cleanSlugTitle;

const dateMatch = slug.match(/(\d{4}-\d{1,2}-\d{1,2})/);
const date = frontmatter.date || (dateMatch ? dateMatch[1] : null);

const tags = isMicro ? ["microblog"] : frontmatter.tags ? frontmatter.tags.split(" ") : [];

// Pre-process raw markdown to encode special chars in image URLs
const rawContent = post.rawContent();
const processedContent = rawContent.replace(
    /!\[([^\]]*)\]\(((?:[^()]+|\([^()]*\))+)\)(\s*\{:\s*\.\w+\s*\})?/g,
    (_match: string, alt: string, url: string, cls: string) => {
        const encoded = url.replace(/\(/g, "%28").replace(/\)/g, "%29").replace(/ /g, "%20");
        return "![" + alt + "](" + encoded + ")" + (cls || "");
    }
);
const processor = await createMarkdownProcessor({
    gfm: true,
    smartypants: true,
    remarkPlugins: [],
    rehypePlugins: [],
});
const { code: bodyHTML } = await processor.render(processedContent);
---

<BaseLayout title={title}>
    <article class="post-item">
        <header class="post-header">
            <h1 class="post-title">{title}</h1>
            {
                date && (
                    <time class="post-date" datetime={date}>
                        {new Date(date).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })}
                    </time>
                )
            }
        </header>

        {
            tags.length > 0 && (
                <div class="post-tags">
                    {tags.map((tag: string) => (
                        <a href={`/tags/${tag}`} class="tag">
                            {tag}
                        </a>
                    ))}
                </div>
            )
        }

        <div class="post-content">
            <Fragment set:html={bodyHTML} />
        </div>
    </article>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const postContent = document.querySelector(".post-content");
            if (!postContent) return;

            postContent.innerHTML = postContent.innerHTML.replace(/\(\:\:([^)]+)\)/g, '<span class="hover-footnote" data-title="$1">*</span>');

            postContent.innerHTML = postContent.innerHTML.replace(
                /<img\s+([^>]*?src="([^"]+)"[^>]*?)>\s*\{\:\.clickableimg\}/g,
                '<a href="$2" target="_blank" rel="noopener noreferrer"><img $1 class="clickableimg"></a>'
            );

            // URL-encode spaces in image src attributes
            postContent.querySelectorAll("img").forEach(function(img) {
                img.src = img.src.replace(/ /g, "%20");
            });
        });
    </script>
</BaseLayout>
